cat > .env.example << 'EOF'
# Apify Configuration
APIFY_TOKEN=your_apify_token_here

# Third-party APIs
PROXYCURL_API_KEY=your_proxycurl_key_here

# Scraping Configuration
MAX_REQUESTS_PER_SOURCE=50
REQUEST_INTERVAL=2000
HEADLESS_BROWSER=true

# Export
EXPORT_FORMAT=json,csv
OUTPUT_PATH=./outputs/
EOF
